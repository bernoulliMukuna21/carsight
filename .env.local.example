# ── Provider mocks (set to true while DVSA/DVLA credentials are pending) ──
DVSA_MOCK=true
DVLA_MOCK=true

# ── DVSA MOT History API (OAuth 2.0 client credentials) ──
DVSA_CLIENT_ID=
DVSA_CLIENT_SECRET=
DVSA_API_KEY=
DVSA_TOKEN_URL=https://login.microsoftonline.com/a455b827-244d-4b55-96b5-3b60ce3c4a12/oauth2/v2.0/token
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_BASE_URL=https://history.mot.api.gov.uk

# ── DVLA Vehicle Enquiry Service ──
DVLA_API_KEY=
DVLA_BASE_URL=https://driver-vehicle-licensing.api.gov.uk

# ── AI Explanation Layer ──
AI_ENABLED=true
ANTHROPIC_API_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
